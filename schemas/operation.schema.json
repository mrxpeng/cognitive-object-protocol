{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cognitiveobjectprotocol.org/schemas/operation.schema.json",
  "title": "COP Operation",
  "type": "object",
  "required": [
    "id",
    "op",
    "actor",
    "created_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^op_[A-Za-z0-9_-]+$"
    },
    "op": {
      "enum": [
        "create_block",
        "update_block",
        "delete_block",
        "move_block",
        "split_block",
        "merge_blocks",
        "add_relation",
        "add_comment",
        "resolve_comment",
        "change_state",
        "create_view",
        "export_view"
      ]
    },
    "target": {
      "type": "string"
    },
    "actor": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "type": {
              "enum": [
                "human",
                "agent",
                "system"
              ]
            },
            "name": {
              "type": "string"
            },
            "display_name": {
              "type": "string"
            },
            "role": {
              "type": "string"
            },
            "auth": {
              "type": "object",
              "properties": {
                "method": {
                  "enum": [
                    "none",
                    "external",
                    "signature",
                    "local"
                  ]
                },
                "provider": {
                  "type": "string"
                },
                "verified": {
                  "type": "boolean"
                }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        }
      ]
    },
    "patch": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": true
        },
        {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "op",
              "path"
            ],
            "properties": {
              "op": {
                "enum": [
                  "add",
                  "remove",
                  "replace"
                ]
              },
              "path": {
                "type": "string"
              },
              "value": {}
            },
            "additionalProperties": false
          }
        }
      ]
    },
    "reason": {
      "type": "string"
    },
    "status": {
      "enum": [
        "proposed",
        "applied",
        "rejected",
        "reverted"
      ]
    },
    "created_at": {
      "type": "string"
    },
    "patch_format": {
      "enum": [
        "object_merge",
        "json_patch"
      ]
    },
    "preconditions": {
      "type": "object",
      "properties": {
        "target_hash": {
          "type": "string"
        },
        "document_version": {
          "type": "number"
        },
        "base_operation": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "result": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
